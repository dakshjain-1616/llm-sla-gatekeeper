# ─────────────────────────────────────────────────────────────
# LLM SLA Gatekeeper — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Model Configuration ────────────────────────────────────────

# Default model path or HuggingFace ID used by the CLI and UI
# Trending models: Qwen/Qwen3-8B, Qwen/Qwen2.5-7B-Instruct, meta-llama/Llama-3.2-3B-Instruct
# Required: no (defaults to Qwen/Qwen2.5-7B-Instruct)
SLA_MODEL_PATH=Qwen/Qwen2.5-7B-Instruct

# ── SLA Thresholds ─────────────────────────────────────────────

# Maximum acceptable average per-token latency in milliseconds
# Required: no (default: 200)
SLA_MAX_LATENCY_MS=200

# Cost in USD per individual token (used for cost-based SLA gate)
# Required: no (default: 0 — disables cost gate)
SLA_COST_PER_TOKEN_USD=0

# Multiplier applied to max_latency_ms to derive the p95 latency limit
# e.g., 1.5 means p95 may be up to 50% higher than avg threshold
# Required: no (default: 1.5)
SLA_P95_MULTIPLIER=1.5

# ── SLA Profile Overrides ──────────────────────────────────────
# Override the thresholds for built-in SLA profiles.
# These are used when --profile=<name> is passed to the CLI.

# chatbot profile (default: 150ms latency, 10 tok/s throughput)
SLA_PROFILE_CHATBOT_LATENCY_MS=150
SLA_PROFILE_CHATBOT_THROUGHPUT=10

# realtime profile (default: 50ms latency, 50 tok/s throughput)
SLA_PROFILE_REALTIME_LATENCY_MS=50
SLA_PROFILE_REALTIME_THROUGHPUT=50

# batch profile (default: 2000ms latency, 1 tok/s throughput)
SLA_PROFILE_BATCH_LATENCY_MS=2000
SLA_PROFILE_BATCH_THROUGHPUT=1

# edge profile (default: 500ms latency, 2 tok/s throughput)
SLA_PROFILE_EDGE_LATENCY_MS=500
SLA_PROFILE_EDGE_THROUGHPUT=2

# dev profile (default: 5000ms latency, no throughput requirement)
SLA_PROFILE_DEV_LATENCY_MS=5000

# ── Benchmark Settings ─────────────────────────────────────────

# Number of tokens to generate per benchmark run
# Required: no (default: 50)
SLA_BENCHMARK_TOKENS=50

# Number of warm-up inference passes before measurement
# Required: no (default: 2)
SLA_WARMUP_RUNS=2

# Number of measured benchmark iterations
# Required: no (default: 5)
SLA_BENCH_RUNS=5

# Maximum retries for real benchmark before falling back to simulation
# Required: no (default: 2)
SLA_BENCH_MAX_RETRIES=2

# Set to "1" or "true" to skip real model loading and use latency simulation.
# Simulation estimates latency from the model's parameter count (parsed from its name).
# Useful for CI/CD pipelines and environments without GPUs/model files.
# Required: no (default: not set — will attempt real inference, fall back to simulation)
SLA_SIMULATION_MODE=1

# ── Output Settings ────────────────────────────────────────────

# Directory where demo.py saves result files
# Required: no (default: outputs)
SLA_OUTPUTS_DIR=outputs

# Path for the validation history JSONL file
# Required: no (default: outputs/history.jsonl)
SLA_HISTORY_FILE=outputs/history.jsonl

# ── Gradio UI Settings ─────────────────────────────────────────

# Network interface for the Gradio server
# Required: no (default: 0.0.0.0)
GRADIO_SERVER_NAME=0.0.0.0

# Port for the Gradio web interface
# Required: no (default: 7860)
GRADIO_SERVER_PORT=7860

# Set to "true" to create a public Gradio share link (requires internet)
# Required: no (default: false)
GRADIO_SHARE=false

# ── Logging ────────────────────────────────────────────────────

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Required: no (default: INFO)
LOG_LEVEL=INFO

# Disable ANSI colour in CLI output (e.g. for CI log parsers)
# NO_COLOR=1
